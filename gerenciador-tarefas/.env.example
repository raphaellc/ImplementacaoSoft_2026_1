# =============================================================================
# Gerenciador de Tarefas — Template de Variáveis de Ambiente
# =============================================================================
# Este arquivo É versionado e serve como documentação das variáveis necessárias.
# Para configurar o projeto: copie este arquivo para .env e preencha os valores.
#
#   cp .env.example .env
#
# O arquivo .env NÃO deve ser commitado (está no .gitignore).
# =============================================================================

# --- Banco de Dados H2 (desenvolvimento) -------------------------------------
# Usuário do banco H2 in-memory. Padrão do H2: "sa"
H2_USER=sa

# Senha do banco H2. Padrão do H2: vazio (sem senha)
H2_PASSWORD=

# --- Banco de Dados MySQL (produção / opcional) ------------------------------
# URL de conexão JDBC com o MySQL
DB_URL=jdbc:mysql://localhost:3306/gerenciador_tarefa

# Usuário do MySQL
DB_USER=root

# Senha do MySQL — obrigatória se usar a implementação MySQL.
# Não possui valor padrão: a ausência causa erro na inicialização.
DB_PASSWORD=

# --- Servidor HTTP ------------------------------------------------------------
# Origem permitida pelo CORS. Em produção, substitua pelo domínio real da aplicação.
CORS_ORIGIN=http://localhost:3000
